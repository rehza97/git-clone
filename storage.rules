rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function repoPath(repoId) {
      return /databases/(default)/documents/repos/$(repoId);
    }
    function repoExists(repoId) {
      return firestore.exists(repoPath(repoId));
    }
    function repoOwnerId(repoId) {
      return firestore.get(repoPath(repoId)).data.ownerId;
    }
    function repoIsPublic(repoId) {
      return firestore.get(repoPath(repoId)).data.visibility == 'public';
    }

    match /users/{userId}/repos/{repoId}/{allPaths=**} {
      // Reads: public repos for anyone; private repos only when path owner is signed in as that user.
      allow read: if repoExists(repoId)
        && repoOwnerId(repoId) == userId
        && (repoIsPublic(repoId) || (request.auth != null && request.auth.uid == userId));

      // MVP writes: only require a signed-in user writing under their own uid prefix.
      // (Firestore rules still gate repo/file metadata.) Before production, re-add:
      // repoOwnerId(repoId) == userId and node_modules / .env path guards.
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
